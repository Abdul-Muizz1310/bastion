NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres (shadow-admin branch repurposed for bastion)
DATABASE_URL=

# iron-session signed cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
IRON_SESSION_PASSWORD=
SESSION_COOKIE_NAME=bastion_session
SESSION_TTL_HOURS=24

# Resend magic link email
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
MAGIC_LINK_TTL_MIN=10

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Ed25519 keypair for platform JWT signing
# Generate: node scripts/generate-keys.mjs
BASTION_SIGNING_KEY_PRIVATE=
BASTION_SIGNING_KEY_PUBLIC=
BASTION_KEY_ID=bastion-ed25519-2026-04

# Demo mode: exposes admin/editor/viewer bypass buttons on /login
DEMO_MODE=true
